# Anthropic API key — powers proposal + brief generation
ANTHROPIC_API_KEY=sk-ant-...

# Apify token — powers the LinkedIn profile scraper
APIFY_TOKEN=apify_api_...

# LinkedIn profile the 07:00 research cron targets
TARGET_LINKEDIN_URL=https://www.linkedin.com/in/example-lead/

# Server port (defaults to 3001) — only used when running server.js on a
# persistent host. Not used on Vercel.
PORT=3001

# --- Persistence transport --------------------------------------------
# Leave all three unset for local dev / a persistent host with real disk:
# files are written straight to ../second-brain on the local filesystem.
#
# Set all three when deploying to Vercel (or any host with an ephemeral or
# read-only filesystem): every generated file is committed directly to the
# GitHub repo via the Contents API instead, so it survives across stateless
# invocations and is immediately visible to the frontend deployment.
GITHUB_TOKEN=ghp_...                      # needs "contents:write" on the repo below
GITHUB_REPO=Profitech123/sales-os         # owner/repo
GITHUB_BRANCH=main

# Verifies that /cron/lead-research is only callable by Vercel's own cron
# scheduler (which sends this value as "Authorization: Bearer <value>").
# Required on Vercel; optional elsewhere.
CRON_SECRET=
